# Kimai — Configuration Example
# Copier ce fichier en .env et remplir les valeurs

# Database
DATABASE_PASSWORD=your_secure_password_here
DATABASE_ROOT_PASSWORD=your_root_password_here

# Kimai
KIMAI_SECRET=generate_with_openssl_rand_hex_32_bytes
KIMAI_URL=http://kimai:8001/api

# SMTP (Gmail ou autre)
SMTP_FROM=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password_here  # For Gmail: Use App Password, not regular password

# API Token
TOKEN_STAN=your_secure_token_here

# Générer secrets sécurisés:
# Linux/Mac: openssl rand -hex 32
# Windows PowerShell: [Convert]::ToHexString((1..32 | % { Get-Random -Max 256 }))
